{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://umfspec.org/schemas/technique.schema.json",
  "title": "UMF Technique Schema",
  "description": "Pedagogical technique card focused on teaching transferable culinary skills rather than describing a finished dish.",
  "type": "object",
  "required": [
    "id",
    "meta",
    "purpose",
    "ingredients",
    "steps"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "meta": {
      "type": "object",
      "required": [
        "title",
        "version"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "Display name of the technique card."
        },
        "authorDisplay": {
          "type": "string",
          "description": "Human-readable author attribution for this technique card."
        },
        "version": {
          "type": "string",
          "description": "Semantic version of the technique card content."
        },
        "formatVersion": {
          "type": "string",
          "description": "Legacy alias for schema_version. Maintained for backward compatibility."
        },
        "schema_version": {
          "type": "string",
          "description": "Canonical schema version identifier. Prefer this field for new implementations."
        },
        "language": {
          "type": "string",
          "description": "Language code using ISO 639-1."
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "beginner",
            "intermediate",
            "advanced",
            "professional"
          ]
        },
        "timeEstimate": {
          "type": "number",
          "description": "Approximate minutes to practice or execute the technique."
        },
        "category": {
          "type": "string",
          "description": "Skill family (e.g., emulsification, braising, knife-work, fermentation)."
        }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "schema_version"
          ]
        },
        {
          "required": [
            "formatVersion"
          ]
        }
      ]
    },
    "purpose": {
      "type": "string",
      "description": "One sentence describing what this technique achieves and why it matters."
    },
    "prerequisites": {
      "type": "array",
      "description": "Canonical names of techniques that should be mastered first.",
      "items": {
        "type": "string"
      }
    },
    "equipment": {
      "type": "array",
      "description": "Required tools for learning/executing the technique.",
      "items": {
        "type": "string"
      }
    },
    "ingredients": {
      "type": "array",
      "description": "Ingredients used to practice the technique (not a finished dish ingredient list).",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "prep": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "ingredientRef": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      }
    },
    "steps": {
      "type": "array",
      "description": "Ordered pedagogical steps for teaching and executing the technique.",
      "items": {
        "type": "object",
        "required": [
          "instruction"
        ],
        "properties": {
          "instruction": {
            "type": "string",
            "description": "Imperative instruction in AUL voice."
          },
          "sensory_cue": {
            "type": "string",
            "description": "What success looks/smells/feels like at this step."
          },
          "timing": {
            "type": "string",
            "description": "Approximate duration or threshold phrase such as 'until cue'."
          },
          "why": {
            "type": "string",
            "description": "Pedagogical rationale, including non-obvious physics/chemistry."
          },
          "media": {
            "type": "object",
            "required": [
              "type",
              "url"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "image",
                  "video",
                  "audio"
                ]
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "role": {
                "type": "string",
                "enum": [
                  "step",
                  "guide"
                ]
              },
              "platform": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "failure_modes": {
      "type": "array",
      "description": "First-class troubleshooting records for teaching and recovery.",
      "items": {
        "type": "object",
        "required": [
          "symptom",
          "cause",
          "prevention"
        ],
        "properties": {
          "symptom": {
            "type": "string"
          },
          "cause": {
            "type": "string"
          },
          "prevention": {
            "type": "string"
          },
          "recovery": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "sensory_checkpoints": {
      "type": "array",
      "description": "Ordered full-process cues indicating the learner is on track.",
      "items": {
        "type": "string"
      }
    },
    "variations": {
      "type": "array",
      "description": "Named deltas from the base technique.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "delta"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "delta": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "cultural_context": {
      "type": "string",
      "description": "Optional origin, regional variation, and historical context."
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "media": {
      "type": "array",
      "description": "Technique-level media assets.",
      "items": {
        "type": "object",
        "required": [
          "type",
          "url"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "image",
              "video",
              "audio"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "role": {
            "type": "string",
            "enum": [
              "hero",
              "step",
              "scan",
              "guide",
              "thumbnail"
            ]
          },
          "platform": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "lineage": {
      "type": "array",
      "description": "Lineage and provenance edges for the technique card.",
      "items": {
        "type": "object",
        "required": [
          "relationship",
          "techniqueRef"
        ],
        "properties": {
          "relationship": {
            "type": "string",
            "enum": [
              "derived_from",
              "variation_of",
              "translation_of",
              "adaptation_of",
              "reinterpretation_of",
              "inspired_by",
              "adapted_from"
            ]
          },
          "techniqueRef": {
            "type": "string",
            "format": "uuid"
          },
          "note": {
            "type": "string"
          },
          "isCanonical": {
            "type": "boolean",
            "description": "Canonical edge flag set by governance process. Do not infer canonical status from edge presence alone."
          }
        },
        "additionalProperties": false
      }
    },
    "extensions": {
      "type": "object",
      "description": "Application-specific extensions. Ignored for interoperability. Known namespaces are documented for cross-implementation awareness but are NOT required.",
      "additionalProperties": true,
      "properties": {
        "ai_metadata": {
          "type": "object"
        },
        "testing_notes": {
          "type": "object"
        },
        "history": {
          "type": "array"
        },
        "shared": {
          "type": "object"
        }
      }
    }
  }
}
